# ===========================================
# STRATIX INTELLIGENCE - Environment Variables
# ===========================================
# Add these in Vercel Dashboard > Settings > Environment Variables

# === AI Providers (REQUIRED) ===
GOOGLE_GEMINI_API_KEY=your_gemini_key
OPENAI_API_KEY=your_openai_key
GROQ_API_KEY=your_groq_key
MISTRAL_API_KEY=your_mistral_key

# === Supabase (REQUIRED) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# === MercadoPago (REQUIRED for checkout) ===
MP_ACCESS_TOKEN=your_mp_access_token
NEXT_PUBLIC_MP_PUBLIC_KEY=your_mp_public_key

# === Email (REQUIRED for notifications) ===
RESEND_API_KEY=your_resend_key

# === App Config ===
NEXT_PUBLIC_APP_URL=https://stratix-intelligence-ia.vercel.app

# === Analytics ===
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# === WhatsApp Business (OPTIONAL - blocked without phone number) ===
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=

